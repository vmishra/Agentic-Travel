# ──────────────────────────────────────────────────────────────────────────
# Agentic Travel — environment configuration
#
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` or any real credentials. `.env` is git-ignored.
# ──────────────────────────────────────────────────────────────────────────

# ── Gemini / Generative AI ─────────────────────────────────────────────────
# API key for Gemini models (text/reasoning, image generation, and Live voice).
GEMINI_API_KEY=

# Model IDs are configurable and validated against your key at startup, so this
# project never hardcodes a model version your key may not expose.
GEMINI_MODEL_PLANNER=        # strong reasoning model — itinerary synthesis & critique
GEMINI_MODEL_FAST=           # fast model — intent, enrichment, specialist agents
GEMINI_MODEL_LIVE=           # realtime model — voice interaction
GEMINI_IMAGE_MODEL=          # image generation model — destination imagery

# ── Google Maps Platform (optional — falls back gracefully if unset) ────────
# Used for interactive map rendering, places, and directions in the frontend.
GOOGLE_MAPS_API_KEY=

# ── Vertex AI / Google Cloud (optional alternative to the API key path) ─────
# Set GOOGLE_GENAI_USE_VERTEXAI=true to route model calls through Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# ── Runtime ─────────────────────────────────────────────────────────────────
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
